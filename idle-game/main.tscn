; main.tscn
;
; Scene tree:
;   Main (Node2D)
;   ├── UI (CanvasLayer)
;   │   ├── Panel               - sidebar background
;   │   ├── CoinLabel           - top of sidebar, always visible
;   │   ├── InfoLabel
;   │   └── ScrollContainer     - buttons scroll if there are too many
;   │       └── ButtonList      - VBoxContainer, buttons added here from main.gd
;   └── CubeContainer (Node2D)  - spawned cubes go here

[gd_scene format=3 uid="uid://bf7fr8v83yujg"]

[ext_resource type="Script" uid="uid://cy7nxld81s8co" path="res://main.gd" id="1_ig7tw"]

[node name="Main" type="Node2D"]
script = ExtResource("1_ig7tw")

; CanvasLayer = Screen Space Canvas in Unity — UI always renders on top
[node name="UI" type="CanvasLayer" parent="."]
layer = 10

[node name="Panel" type="Panel" parent="UI"]
offset_right  = 200.0
offset_bottom = 600.0

[node name="CoinLabel" type="Label" parent="UI"]
offset_left   = 6.0
offset_top    = 6.0
offset_right  = 194.0
offset_bottom = 46.0
autowrap_mode = 3
text = "Coins: 0"

[node name="InfoLabel" type="Label" parent="UI"]
offset_left   = 6.0
offset_top    = 50.0
offset_right  = 194.0
offset_bottom = 68.0
text = "Cubes: 0"

; ScrollContainer lets the button list scroll if it overflows the sidebar height
[node name="ScrollContainer" type="ScrollContainer" parent="UI"]
offset_left           = 0.0
offset_top            = 74.0
offset_right          = 200.0
offset_bottom         = 600.0
horizontal_scroll_mode = 0

; VBoxContainer auto-stacks children vertically — same as a Vertical Layout Group in Unity
[node name="ButtonList" type="VBoxContainer" parent="UI/ScrollContainer"]
layout_mode            = 2
size_flags_horizontal  = 3

; Empty Node2D acting as a parent container for runtime-spawned cubes
[node name="CubeContainer" type="Node2D" parent="."]

; Camera2D = Unity Camera — zoom and position controlled from main.gd
[node name="Camera2D" type="Camera2D" parent="."]
