; Cube.tscn
; ===================================================================
; The Cube "prefab" (Godot equivalent of a Unity Prefab)
;
; Unity equivalent hierarchy:
;   Cube (GameObject with Rigidbody2D + trigger Collider2D)
;   ├── ColorRect     ← SpriteRenderer (solid blue square)
;   ├── CollisionShape2D ← BoxCollider2D (trigger)
;   ├── PassiveTimer  ← InvokeRepeating timer
;   └── ClickLabel    ← TextMeshPro "+N" popup
; ===================================================================
[gd_scene format=3 uid="uid://cube_scene_v1"]

[ext_resource type="Script" path="res://Cube.gd" id="1_cube"]

[sub_resource type="RectangleShape2D" id="Shape_1"]
size = Vector2(64, 64)

; Root node — Area2D so it can receive mouse input events
[node name="Cube" type="Area2D"]
script = ExtResource("1_cube")

; The visible blue square (sits centred at origin)
[node name="ColorRect" type="ColorRect" parent="."]
offset_left   = -32.0
offset_top    = -32.0
offset_right  =  32.0
offset_bottom =  32.0
color = Color(0.18, 0.55, 0.95, 1.0)

; Collision shape — matches the ColorRect exactly
[node name="CollisionShape2D" type="CollisionShape2D" parent="."]
shape = SubResource("Shape_1")

; Passive income timer — fires every 1 second
[node name="PassiveTimer" type="Timer" parent="."]
wait_time = 1.0
autostart = true

; Floating "+N" click feedback label
[node name="ClickLabel" type="Label" parent="."]
offset_left   = -32.0
offset_top    = -58.0
offset_right  =  32.0
offset_bottom = -38.0
horizontal_alignment = 1
text = "+1"
visible = false

; Wire the timer timeout signal to the script method
[connection signal="timeout" from="PassiveTimer" to="." method="_on_passive_timer_timeout"]
